# ══════════════════════════════════════════════════════════════
#  .env.example — Приклад файлу конфігурації
#  Скопіюйте цей файл в .env і заповніть реальними значеннями
# ══════════════════════════════════════════════════════════════

# ── Telegram Bot ──────────────────────────────────────────────
# Отримати у @BotFather
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OpenWeatherMap ────────────────────────────────────────────
# Реєстрація: https://openweathermap.org/api
# Безкоштовний план: 60 запитів/хв, 1M/місяць
OPENWEATHER_KEY=your_openweathermap_api_key_here

# ── NewsAPI ───────────────────────────────────────────────────
# Реєстрація: https://newsapi.org/register
# Безкоштовний план: 100 запитів/день
NEWS_KEY=your_newsapi_key_here

# ── Fernet (шифрування БД) ────────────────────────────────────
# Генерація: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your_fernet_key_here_base64_encoded=

# ── Переклад (необов'язково) ──────────────────────────────────
# Google Cloud Translation API (якщо є)
TRANSLATE_KEY=

# DeepL API (безкоштовно до 500K символів/місяць)
# Реєстрація: https://www.deepl.com/pro-api
DEEPL_KEY=

# ── База даних ────────────────────────────────────────────────
# SQLite (локально, за замовчуванням):
DATABASE_URL=sqlite+aiosqlite:///bot_data.db

# PostgreSQL (для продакшн):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/botdb
